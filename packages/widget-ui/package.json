{
  "name": "@trakr/widget-ui",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "tsc && tailwindcss -i ./src/styles.css -o ./dist/styles.css --minify",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@trakr/schemas": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.8",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3"
  }
}
