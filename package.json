{
  "name": "trakr-labs",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @trakr/api db:generate",
    "db:migrate": "pnpm --filter @trakr/api db:migrate",
    "db:push": "pnpm --filter @trakr/api db:push",
    "db:studio": "pnpm --filter @trakr/api db:studio",
    "postinstall": "pnpm db:generate"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
