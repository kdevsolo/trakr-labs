generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum PermissionResource {
  PROJECT
  USER
}

enum PermissionAction {
  READ
  CREATE
  UPDATE
  DELETE
}

enum UserInviteStatus {
  PENDING
  ACCEPTED
}

model User {
  id         String  @id
  name       String
  email      String  @unique
  orgId      String?
  isOrgAdmin            Boolean   @default(false)
  tncAccepted           Boolean   @default(false)
  tncAcceptingTimestamp DateTime?

  org              Organization?      @relation(fields: [orgId], references: [id])
  projectMembers   ProjectMember[]
  permissions      MemberPermission[]
  invite           UserInvite?
  reportedIssues   Issue[]            @relation("IssueReporter")
  assignedIssues Issue[]            @relation("IssueAssignee")
  comments         Comment[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([orgId])
}

model UserInvite {
  id        String           @id @default(uuid())
  userId    String           @unique
  orgId     String
  invitedBy String
  status    UserInviteStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([status])
}

model Organization {
  id         String   @id @default(uuid())
  name       String
  ownerId    String
  createdBy  String
  modifiedBy String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  users               User[]
  projects            Project[]
  permissions         MemberPermission[]
  statuses            StatusMaster[]
  githubInstallations GithubInstallation[]
}

model Project {
  id               String   @id @default(uuid())
  name             String
  projectKey       String   @unique
  orgId            String
  widgetEnabled           Boolean  @default(false)
  widgetSecretHash        String? // sha256 hash; null until enabled
  widgetSecretEnc         String? // AES-GCM encrypted secret for dashboard display
  widgetAutoCrashReport   Boolean  @default(true)
  widgetAutoNetworkReport Boolean  @default(true)
  createdBy        String
  modifiedBy       String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  org            Organization       @relation(fields: [orgId], references: [id])
  members        ProjectMember[]
  permissions    MemberPermission[]
  issues         Issue[]
  repoConnection RepoConnection?

  @@index([orgId])
}

model ProjectMember {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  addedBy   String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId])
}

model MemberPermission {
  id        String             @id @default(uuid())
  userId    String
  orgId     String
  projectId String?
  resource  PermissionResource
  action    PermissionAction
  grantedBy String
  createdAt DateTime           @default(now())

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId, projectId, resource, action])
  @@index([userId, projectId])
  @@index([orgId])
}

model Issue {
  id          String   @id @default(uuid())
  title       String
  description String?
  metadata    Json?
  statusId    String
  projectId   String
  reportedBy  String?
  assignedTo  String?
  assignedBy  String?
  modifiedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  status   StatusMaster @relation(fields: [statusId], references: [id])
  project  Project      @relation(fields: [projectId], references: [id])
  reporter User?        @relation("IssueReporter", fields: [reportedBy], references: [id])
  assignee User?        @relation("IssueAssignee", fields: [assignedTo], references: [id])
  comments Comment[]
  media    IssueMedia[]

  @@index([projectId])
  @@index([statusId])
  @@index([reportedBy])
  @@index([assignedTo])
  @@index([projectId, createdAt(sort: Desc)])
  @@index([projectId, statusId])
}

model Comment {
  id        String   @id @default(uuid())
  issueId   String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  issue  Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@index([authorId])
  @@index([issueId, createdAt])
}

model IssueMedia {
  id        String   @id @default(uuid())
  issueId   String
  url       String
  fileType  String?
  createdAt DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId])
}

model StatusMaster {
  id        String   @id @default(uuid())
  orgId     String
  title     String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org    Organization @relation(fields: [orgId], references: [id])
  issues Issue[]

  @@unique([orgId, title])
  @@index([orgId])
}

model GithubInstallation {
  id             String   @id @default(uuid())
  orgId          String
  installationId Int      @unique
  accountLogin   String
  accountType    String
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model RepoConnection {
  id             String   @id @default(uuid())
  projectId      String   @unique
  installationId Int
  repoOwner      String
  repoName       String
  repoId         Int
  defaultBranch  String
  connectedBy    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([installationId])
}
