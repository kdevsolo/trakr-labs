DATABASE_URL="postgresql://postgres:postgres@localhost:5432/trakr_labs?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/trakr_labs?schema=public"
PORT=3001
# Web app origin(s) — comma-separated for local + production. Used for CORS and invite redirects.
FRONTEND_URL="http://localhost:3000"
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# Widget feedback storage — create bucket "widget-feedback" in Supabase Storage (private).
# Run prisma/supabase-widget-feedback-bucket.sql in the Supabase SQL editor.
# Existing public buckets: set public = false in Storage settings, then rely on signed URLs.
WIDGET_STORAGE_BUCKET="widget-feedback"
WIDGET_MAX_FILE_SIZE_BYTES=5242880
WIDGET_MAX_MEDIA_COUNT=5
